{"parentUuid":"6cc652c5-2fe6-48a8-a48c-2673c3fd0d6a","isSidechain":false,"userType":"external","cwd":"C:\\Users\\Administrator\\.local\\bin","sessionId":"9d885d2b-2e08-431b-94cb-2dc40f2ac0af","version":"2.1.7","gitBranch":"","slug":"fizzy-wobbling-lollipop","message":{"id":"a166341b-2693-4092-9faf-e7d748594872","type":"message","role":"assistant","model":"deepseek-reasoner","content":[{"type":"tool_use","id":"call_00_NcZkvvElZZGEj4Dca6HK2aEh","name":"Write","input":{"file_path":"D:/办公区/PTO项目相关/SLZ工作/志荣工作交接/KPI&Settlement/代维工作量汇总/merge_tmc_v3.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n合并所有TMC开头的Excel文件中的Emergency support工作表数据\n提取指定列，添加上级目录名作为新列，输出到新Excel文件\n版本3：根据文件夹结构智能确定上级目录名称\n\"\"\"\nimport os\nimport pandas as pd\nimport sys\n\ndef find_tmc_excel_files(root_dir):\n    \"\"\"递归查找所有以TMC开头的.xlsx文件\"\"\"\n    tmc_files = []\n    for dirpath, dirnames, filenames in os.walk(root_dir):\n        for filename in filenames:\n            if filename.lower().startswith('tmc') and filename.lower().endswith('.xlsx'):\n                full_path = os.path.join(dirpath, filename)\n                tmc_files.append(full_path)\n    return tmc_files\n\ndef get_parent_directory_name(file_path):\n    \"\"\"智能获取上级目录名称\n\n    规则：\n    1. 如果文件所在文件夹名称与父文件夹名称相同（嵌套结构），则使用父文件夹的父文件夹名称\n    2. 否则使用文件所在文件夹名称\n    3. 对于202509及之后的月份，文件直接放在月份文件夹中，使用文件所在文件夹名称\n    \"\"\"\n    # 文件所在目录\n    dir_path = os.path.dirname(file_path)\n    dir_name = os.path.basename(dir_path)\n\n    # 父目录\n    parent_dir = os.path.dirname(dir_path)\n    parent_dir_name = os.path.basename(parent_dir)\n\n    # 判断是否为嵌套结构（如202501/202501/）\n    if dir_name == parent_dir_name:\n        # 嵌套结构，使用祖父目录名称\n        grandparent_dir = os.path.dirname(parent_dir)\n        return os.path.basename(grandparent_dir)\n    else:\n        # 扁平结构，直接使用所在目录名称\n        return dir_name\n\ndef extract_data_from_file(file_path):\n    \"\"\"从单个文件中提取Emergency support工作表的指定列\"\"\"\n    try:\n        # 读取Excel文件，获取所有工作表名称\n        xl = pd.ExcelFile(file_path)\n        # 查找Emergency support工作表（可能有空格后缀）\n        target_sheet = None\n        for sheet in xl.sheet_names:\n            if 'Emergency support' in sheet:\n                target_sheet = sheet\n                break\n        if target_sheet is None:\n            print(f\"警告: {file_path} 中未找到Emergency support工作表\")\n            return None\n\n        # 读取工作表，跳过前6行，将第7行作为表头（索引从0开始）\n        df = pd.read_excel(file_path, sheet_name=target_sheet, skiprows=6, header=0)\n\n        # 检查是否有所需的列（前4列）\n        if df.shape[1] < 4:\n            print(f\"警告: {file_path} 中列数不足4列\")\n            return None\n\n        # 提取前4列，忽略后面的列\n        column_names = ['物理站点编码', '工作量内容', '数量', '金额']\n        df_extracted = df.iloc[:, :4].copy()\n        df_extracted.columns = column_names\n\n        # 删除全为空的行\n        df_extracted = df_extracted.dropna(how='all')\n\n        # 删除表头行（即第一列等于\"物理站点编码\"的行）\n        mask = df_extracted['物理站点编码'] == '物理站点编码'\n        if mask.any():\n            df_extracted = df_extracted[~mask].reset_index(drop=True)\n\n        # 确保数值列为数字类型\n        df_extracted['数量'] = pd.to_numeric(df_extracted['数量'], errors='coerce')\n        df_extracted['金额'] = pd.to_numeric(df_extracted['金额'], errors='coerce')\n\n        # 添加上级目录名作为新列\n        parent_dir = get_parent_directory_name(file_path)\n        df_extracted.insert(0, '上级目录', parent_dir)\n\n        return df_extracted\n\n    except Exception as e:\n        print(f\"处理文件 {file_path} 时出错: {e}\")\n        import traceback\n        traceback.print_exc()\n        return None\n\ndef main():\n    root_dir = r\"D:\\办公区\\PTO项目相关\\SLZ工作\\志荣工作交接\\KPI&Settlement\\代维工作量汇总\"\n    if not os.path.exists(root_dir):\n        print(f\"错误: 目录不存在 {root_dir}\")\n        sys.exit(1)\n\n    print(\"正在查找TMC开头的Excel文件...\")\n    tmc_files = find_tmc_excel_files(root_dir)\n\n    if not tmc_files:\n        print(\"未找到任何TMC开头的Excel文件\")\n        sys.exit(1)\n\n    print(f\"找到 {len(tmc_files)} 个TMC文件:\")\n    for f in tmc_files:\n        print(f\"  {f}\")\n\n    all_data = []\n    for file_path in tmc_files:\n        print(f\"处理: {file_path}\")\n        df = extract_data_from_file(file_path)\n        if df is not None and not df.empty:\n            all_data.append(df)\n            print(f\"  提取了 {len(df)} 行数据，上级目录: {df['上级目录'].iloc[0]}\")\n        else:\n            print(f\"  未提取到数据\")\n\n    if not all_data:\n        print(\"未提取到任何数据\")\n        sys.exit(1)\n\n    # 合并所有数据\n    merged_df = pd.concat(all_data, ignore_index=True)\n\n    # 输出文件路径\n    output_file = os.path.join(os.getcwd(), \"merged_emergency_support_v3.xlsx\")\n\n    # 保存到Excel\n    merged_df.to_excel(output_file, index=False)\n    print(f\"合并完成! 共 {len(merged_df)} 行数据\")\n    print(f\"输出文件: {output_file}\")\n\nif __name__ == \"__main__\":\n    main()"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":558,"cache_creation_input_tokens":0,"cache_read_input_tokens":47552,"output_tokens":1408,"service_tier":"standard"}},"type":"assistant","uuid":"b60ad9fa-1064-4a79-825f-78228c16ecd4","timestamp":"2026-03-16T01:54:58.170Z"}
